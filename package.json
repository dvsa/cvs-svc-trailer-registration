{
  "name": "cvs-svc-trailer-registration",
  "version": "0.0.0",
  "description": "A service to allow Trailer owners to apply for a registration mark for their trailer from DVLA. This will deliver the capability for DVSA to receive VRM so that thet can be printed on trailer MOT where it is available.",
  "main": "handler.js",
  "engines": {
    "node": "12.x",
    "npm": "6.x"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run security && npm run audit",
      "commit-msg": "npm run lint && npm run prettier && commitlint -E HUSKY_GIT_PARAMS",
      "pre-push": "echo 'run tests here'"
    }
  },
  "scripts": {
    "start": "SLS_DEBUG=* serverless offline",
    "test": "echo \"Error: no test specified\" && exit 1",
    "audit": "npm audit",
    "lint": "eslint . --ext js,ts --fix",
    "prettier": "prettier --write './**/*.{js,ts}'",
    "security": "git secrets --scan && git log -p | scanrepo",
    "clean": "rimraf ./build",
    "compile": "npm run clean && tsc --noEmit -p .",
    "build": "npm run clean && serverless webpack -o ./build",
    "deploy": "echo 'run \"serveless deploy\" with production .env file - \".env.production\"'"
  },
  "dependencies": {
    "source-map-support": "^0.5.19"
  },
  "devDependencies": {
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@serverless/typescript": "^2.12.0",
    "@types/aws-lambda": "^8.10.64",
    "@types/node": "^14.14.6",
    "@typescript-eslint/eslint-plugin": "^4.9.1",
    "@typescript-eslint/parser": "^4.9.1",
    "commitlint-plugin-function-rules": "^1.1.20",
    "eslint": "^7.15.0",
    "eslint-config-prettier": "^7.0.0",
    "eslint-plugin-prettier": "^3.3.0",
    "fork-ts-checker-webpack-plugin": "^6.0.6",
    "husky": "^4.3.6",
    "prettier": "^2.2.1",
    "rimraf": "^3.0.2",
    "serverless": "^2.15.0",
    "serverless-dotenv-plugin": "^3.1.0",
    "serverless-offline": "^6.8.0",
    "serverless-webpack": "^5.2.0",
    "ts-loader": "^8.0.10",
    "ts-node": "^9.0.0",
    "typescript": "^4.0.5",
    "webpack": "^5.4.0",
    "webpack-node-externals": "^2.5.2"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dvsa/cvs-svc-trailer-registration/issues"
  },
  "homepage": "https://github.com/dvsa/cvs-svc-trailer-registration#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvsa/cvs-svc-trailer-registration.git"
  },
  "keywords": [
    "DVLA",
    "DVSA",
    "CVS",
    "Trailer",
    "TRL",
    "VRM",
    "MOT"
  ]
}
